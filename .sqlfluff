[sqlfluff]
# Snowflake SQL dialect — understands QUALIFY, SAMPLE, FLATTEN, etc.
dialect = snowflake
# Use the jinja templater so {{ ref() }} and {{ source() }} don't cause parse errors
templater = jinja
sql_file_exts = .sql
max_line_length = 120

[sqlfluff:rules:capitalisation.keywords]
# SELECT, FROM, WHERE, JOIN etc. must be UPPERCASE
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.functions]
# COUNT(), COALESCE(), UPPER() etc. must be UPPERCASE
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
# VARCHAR, NUMBER, TIMESTAMP_NTZ etc. must be UPPERCASE
capitalisation_policy = upper

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4
